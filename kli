#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FAT_JAR="$ROOT_DIR/build/libs/kotlin-cli.jar"

if [[ ! -f "$FAT_JAR" ]]; then
    echo "error: kli fat jar not found at $FAT_JAR" >&2
    echo "Run './gradlew build' to build the fat jar." >&2
    exit 1
fi

exec java -jar "$FAT_JAR" "$@"
